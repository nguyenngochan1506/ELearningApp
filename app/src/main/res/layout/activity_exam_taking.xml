<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- A. Header (Cố định) -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/primary_color"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Tên bài kiểm tra -->
        <TextView
            android:id="@+id/tv_exam_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bài kiểm tra giữa kỳ - Lập trình Python"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"/>

        <!-- Thời gian còn lại -->
        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:15:23"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:layout_marginTop="8dp"/>

        <!-- Nút Nộp bài -->
        <Button
            android:id="@+id/btn_submit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:text="Nộp bài"
            android:backgroundTint="@android:color/holo_red_dark"
            android:textColor="@android:color/white"/>
    </LinearLayout>

    <!-- B. Khu vực câu hỏi & trả lời -->
    <!-- Danh sách câu hỏi -->
    <HorizontalScrollView
        android:id="@+id/hsv_questions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/header_layout"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/questions_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <!-- Danh sách câu hỏi động, thêm trong code -->
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Nội dung câu hỏi -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/hsv_questions"
        app:layout_constraintBottom_toTopOf="@id/footer_layout"
        android:padding="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Số thứ tự câu hỏi -->
            <TextView
                android:id="@+id/tv_question_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Câu 1/20"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- Nội dung câu hỏi -->
            <TextView
                android:id="@+id/tv_question_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Câu hỏi: Viết chương trình Python in dãy Fibonacci."
                android:textSize="16sp"
                app:layout_constraintTop_toBottomOf="@id/tv_question_number"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="8dp"/>

            <!-- Hỗ trợ đa phương tiện -->
            <ImageView
                android:id="@+id/iv_question_media"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tv_question_content"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="8dp"/>

            <!-- Khu vực trả lời -->
            <!-- Trắc nghiệm -->
            <RadioGroup
                android:id="@+id/rg_answers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/iv_question_media"
                app:layout_constraintStart_toStartOf="parent">
                <!-- RadioButton động, thêm trong code -->
            </RadioGroup>

            <!-- Tự luận -->
            <EditText
                android:id="@+id/et_essay_answer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập câu trả lời..."
                android:visibility="gone"
                android:inputType="textMultiLine"
                app:layout_constraintTop_toBottomOf="@id/iv_question_media"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="8dp"/>

            <!-- Điền khuyết -->
            <EditText
                android:id="@+id/et_fill_in_the_blank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Điền vào chỗ trống..."
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/iv_question_media"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="8dp"/>

            <!-- Word count cho tự luận -->
            <TextView
                android:id="@+id/tv_word_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/500 từ"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/et_essay_answer"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- C. Footer -->
    <LinearLayout
        android:id="@+id/footer_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/primary_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Nút Câu trước -->
        <Button
            android:id="@+id/btn_previous"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Câu trước"
            android:backgroundTint="@android:color/holo_blue_light"
            android:textColor="@android:color/white"/>

        <!-- Nút Đánh dấu -->
        <Button
            android:id="@+id/btn_flag"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Đánh dấu"
            android:backgroundTint="@android:color/holo_orange_light"
            android:textColor="@android:color/white"
            android:layout_marginStart="8dp"/>

        <!-- Nút Câu sau -->
        <Button
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Câu sau"
            android:backgroundTint="@android:color/holo_blue_light"
            android:textColor="@android:color/white"
            android:layout_marginStart="8dp"/>

        <!-- Thanh tiến độ -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:layout_marginStart="8dp"
            android:max="100"
            android:progress="0"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>